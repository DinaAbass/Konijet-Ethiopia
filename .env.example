# Public env vars (exposed to browser bundle — only for non-secret keys)
NEXT_PUBLIC_OPENWEATHER_API_KEY=your-openweather-api-key
NEXT_PUBLIC_GOOGLE_ADSENSE_ID=ca-pub-xxxxxxxxxx

# ── APPWRITE (Server-side only — never expose to browser) ──
APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=your-appwrite-project-id
APPWRITE_API_KEY=your-appwrite-api-key
APPWRITE_DATABASE_ID=your-appwrite-database-id
APPWRITE_DESTINATIONS_COLLECTION_ID=destinations
APPWRITE_PACKAGES_COLLECTION_ID=packages
APPWRITE_BOOKINGS_COLLECTION_ID=bookings
APPWRITE_LEADS_COLLECTION_ID=leads
APPWRITE_CONTACTS_COLLECTION_ID=contacts
APPWRITE_BUCKET_ID=your-appwrite-bucket-id
# ── APPWRITE (Public — safe for browser) ──
NEXT_PUBLIC_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
NEXT_PUBLIC_APPWRITE_PROJECT_ID=your-appwrite-project-id
NEXT_PUBLIC_APPWRITE_DATABASE_ID=your-appwrite-database-id
NEXT_PUBLIC_APPWRITE_DESTINATIONS_COLLECTION_ID=destinations
NEXT_PUBLIC_APPWRITE_PACKAGES_COLLECTION_ID=packages
NEXT_PUBLIC_APPWRITE_BUCKET_ID=your-appwrite-bucket-id
# ── n8n WEBHOOKS (Server-side only — never expose) ──
N8N_BOOKING_WEBHOOK_URL=https://your-n8n-instance.com/webhook/konjit-booking
N8N_NEWSLETTER_WEBHOOK_URL=https://your-n8n-instance.com/webhook/konjit-newsletter
N8N_CONTACT_WEBHOOK_URL=https://your-n8n-instance.com/webhook/konjit-contact
# ── n8n WEBHOOKS (Public — needed by browser for client-side form posts) ──
NEXT_PUBLIC_N8N_BOOKING_WEBHOOK_URL=https://your-n8n-instance.com/webhook/konjit-booking
NEXT_PUBLIC_N8N_NEWSLETTER_WEBHOOK_URL=https://your-n8n-instance.com/webhook/konjit-newsletter
NEXT_PUBLIC_N8N_CONTACT_WEBHOOK_URL=https://your-n8n-instance.com/webhook/konjit-contact
# ── ADMIN WEBHOOK SECURITY ──
ADMIN_WEBHOOK_SECRET=your-admin-webhook-secret
# ── BREVO ──
BREVO_API_KEY=your-brevo-api-key
BREVO_SENDER_EMAIL=hello@yourdomain.com
BREVO_SENDER_NAME=Your Company Name
BREVO_LIST_ID=2
# ── CONTACT & SOCIAL ──
NEXT_PUBLIC_WHATSAPP_NUMBER=+251900000000
NEXT_PUBLIC_COMPANY_EMAIL=info@yourdomain.com
NEXT_PUBLIC_BASE_URL=https://yourdomain.com
# ── GITHUB (for n8n blog publishing) ──
GITHUB_REPO_OWNER=your-github-username
GITHUB_REPO_NAME=your-repo-name
GITHUB_TOKEN=ghp_your-github-token
